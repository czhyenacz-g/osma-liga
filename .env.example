# GoatCounter analytics (optional)
NEXT_PUBLIC_GOATCOUNTER_CODE=

# Project Hub API — výsledky zápasů se ukládají přes tuto API vrstvu
# Pro lokální vývoj: nastav PROJECT_HUB_API_URL na http://localhost:3001
PROJECT_HUB_API_URL=https://api.osmaliga.cz
PROJECT_HUB_API_KEY=change_me

# WebSocket URL pro online multiplayer
# Pro lokální vývoj: http://localhost:3001
NEXT_PUBLIC_PROJECT_HUB_WS_URL=https://api.osmaliga.cz

# PostgreSQL (přímé připojení — nahrazeno Hub API, lze vynechat)
# DATABASE_URL="postgresql://osmaliga:secret@localhost:5432/osmaliga"
